# Frontend environment variables (example)
# Copy to .env.local (or another .env* file) and fill in real values.

# API base URL used by the browser
# Use http://localhost:8080 for docker-compose dev.
# Leave empty in production when frontend nginx proxies /api and /socket.io.
VITE_API_URL=http://localhost:8080

# Clerk (Auth)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
